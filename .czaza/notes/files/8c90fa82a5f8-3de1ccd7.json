      "anchorHash": "sha256:11486342528f4fd701c677ea7dbfb4877b4039abc9c798a224e039b99af7c615",
      "aiExplanation": {
        "summary": "描述文件的主要职责。",
        "detail": "简要说明此文件注册VS Code事件以实现笔记预览的同步更新。"
      }
    },
    "section:2:registernotespreviewevents:9-85": {
      "title": "registerNotesPreviewEvents",
      "range": {
        "startLine": 9,
        "endLine": 85
      },
      "anchorHash": "sha256:eddbbadef7c868e90f2026aa150d6b4ee28b1b303110aa28ca963b3b20c339c5",
      "aiExplanation": {
        "summary": "注册事件监听器以跟踪活跃编辑器和选项卡。",
        "detail": "定义内部函数 `followResource`、`followEditor` 和 `followActiveTab`，分别用于根据资源URI、编辑器或选项卡更新预览。内部函数维护 `lastPreviewLocation` 以避免重复更新。最后，将事件订阅推送到 `context.subscriptions` 并在当前活跃状态下初始化一次预览。捕获错误并记录到控制台。"
      }
    },
    "section:3:gettabresourceuri:87-103": {
      "title": "getTabResourceUri",
      "range": {
        "startLine": 87,
        "endLine": 103
      },
      "anchorHash": "sha256:d9673917c06125320f4fabc8e23656ded3b053e321d45d17f9735b5420fbc6a9",
      "aiExplanation": {
        "summary": "从选项卡中提取资源URI。",
        "detail": "根据选项卡输入的类型（文本、自定义、笔记本、差异视图等）返回对应的URI。如果不是已知类型则返回undefined。"
      }
    }
