{
  "language": "en",
  "outDir": ".czaza",
  "scan": {
    "maxDepth": 8,
    "maxEntries": 5000,
    "rules": {
      "ignore": [
        ".git/",
        ".svn/",
        ".hg/",
        ".idea/",
        ".turbo/",
        ".expo/",
        ".vercel/",
        ".netlify/",
        "coverage/",
        ".nyc_output/",
        "__pycache__/",
        ".pytest_cache/",
        ".venv/",
        "venv/",
        ".gradle/",
        "bin/",
        "obj/",
        ".DS_Store"
      ],
      "collapseOnly": [
        "node_modules/",
        ".next/",
        ".cache/",
        "dist/",
        "build/",
        "target/",
        "public/",
        "assets/",
        "images/",
        "icons/",
        "fonts/",
        "tests/"
      ]
    }
  }
}
