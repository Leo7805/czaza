{
  "name": "czaza",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && vite build --config vite.webview.config.ts",
    "build:webview": "vite build --config vite.webview.config.ts",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:copy-for-ai": "vitest run tests/copyForAI/copyForAI.test.ts --reporter=verbose",
    "build:vscode": "tsup vscode/extension.ts --tsconfig tsconfig.node.json --format cjs --platform node --external vscode --out-dir dist/vscode",
    "package:vscode": "npm run build:vscode && vsce package",
    "watch:vscode": "tsup vscode/extension.ts --tsconfig tsconfig.node.json --format cjs --platform node --external vscode --out-dir dist/vscode --watch"
  },
  "dependencies": {
    "@noble/hashes": "^2.2.0",
    "picomatch": "^4.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "1.100.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "oxlint": "^1.71.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  },
  "main": "./dist/vscode/extension.cjs",
  "engines": {
    "vscode": "^1.100.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:czaza.notesView",
    "onCommand:czaza.showNotes"
  ],
  "contributes": {
    "configuration": {
      "title": "CZaza",
      "type": "object",
      "properties": {
        "czaza.ai.provider": {
          "type": "string",
          "scope": "application",
          "default": "deepseek",
          "enum": [
            "deepseek"
          ],
          "enumItemLabels": [
            "DeepSeek"
          ],
          "markdownEnumDescriptions": [
            "Use DeepSeek as the AI service provider."
          ],
          "description": "Selects the AI service provider used by CZaza.",
          "order": 1
        },
        "czaza.ai.model": {
          "type": "string",
          "scope": "application",
          "default": "deepseek-v4-flash",
          "enum": [
            "deepseek-v4-flash",
            "deepseek-v4-pro"
          ],
          "enumItemLabels": [
            "DeepSeek V4 Flash",
            "DeepSeek V4 Pro"
          ],
          "markdownEnumDescriptions": [
            "Use the DeepSeek V4 Flash model.",
            "Use the DeepSeek V4 Pro model."
          ],
          "description": "Selects the AI model used by CZaza.",
          "order": 2
        },
        "czaza.ai.responseLanguage": {
          "type": "string",
          "scope": "application",
          "default": "en",
          "enum": [
            "en",
            "zh-CN"
          ],
          "enumItemLabels": [
            "English",
            "简体中文"
          ],
          "markdownEnumDescriptions": [
            "Generate AI explanations in English.",
            "Generate AI explanations in Simplified Chinese."
          ],
          "description": "Selects the language used for AI-generated explanations.",
          "order": 3
        },
        "czaza.outputDirectory": {
          "type": "string",
          "scope": "resource",
          "default": ".czaza",
          "description": "Workspace-relative directory used for files generated by CZaza.",
          "order": 4
        },
        "czaza.rootDirectory": {
          "type": "string",
          "scope": "resource",
          "default": "",
          "description": "Root directory where CZaza notes and analysis are enabled. Relative paths are resolved from the current VS Code workspace folder. Leave empty to use the workspace folder.",
          "order": 5
        }
      }
    },
    "commands": [
      {
        "command": "czaza.showNotes",
        "title": "CZaza: Show Notes"
      },
      {
        "command": "czaza.copyForAI.copyFile",
        "title": "CZaza: Copy File ❤️",
        "icon": "$(diff)"
      },
      {
        "command": "czaza.copyForAI.copyFileDiff",
        "title": "CZaza: Copy File Diff ❤️",
        "icon": "$(diff)"
      },
      {
        "command": "czaza.showCurrentSettings",
        "title": "Show Current Settings",
        "category": "CZaza"
      },
      {
        "command": "czaza.manageApiKeys",
        "title": "Manage API Keys",
        "category": "CZaza"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "czaza.copyForAI.copyFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@2"
        },
        {
          "command": "czaza.copyForAI.copyFileDiff",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@3"
        },
        {
          "command": "czaza.showNotes",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "navigation@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "czaza.copyForAI.copyFile",
          "when": "resourceScheme == file",
          "group": "1_cutcopypaste@200"
        },
        {
          "command": "czaza.copyForAI.copyFileDiff",
          "when": "resourceScheme == file",
          "group": "1_cutcopypaste@201"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "czaza",
          "title": "CZaza",
          "icon": "media/czaza-icon.svg"
        }
      ]
    },
    "views": {
      "czaza": [
        {
          "type": "webview",
          "id": "czaza.notesView",
          "name": "CZaza Notes"
        }
      ]
    }
  }
}
