{
  "name": "czaza",
  "private": true,
  "version": "0.1.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:copy-for-ai": "vitest run tests/copyForAI/copyForAI.test.ts --reporter=verbose",
    "build:vscode": "tsup vscode/extension.ts --tsconfig tsconfig.node.json --format cjs --platform node --external vscode --out-dir dist/vscode",
    "package:vscode": "npm run build:vscode && vsce package",
    "watch:vscode": "tsup vscode/extension.ts --tsconfig tsconfig.node.json --format cjs --platform node --external vscode --out-dir dist/vscode --watch"
  },
  "dependencies": {
    "picomatch": "^4.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "1.100.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "oxlint": "^1.71.0",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  },
  "main": "./dist/vscode/extension.cjs",
  "engines": {
    "vscode": "^1.100.0"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:czaza.descriptionView",
    "onCommand:czaza.showDescription",
    "onCommand:czaza.analyzeFileStructure",
    "onCommand:czaza.analyzeSemantic",
    "onCommand:czaza.analyzeLineRange"
  ],
  "contributes": {
    "commands": [
      {
        "command": "czaza.showDescription",
        "title": "CZaza: Show Description"
      },
      {
        "command": "czaza.analyzeFileStructure",
        "title": "CZaza: Analyze File Structure"
      },
      {
        "command": "czaza.analyzeSemantic",
        "title": "CZaza: Analyze Semantic Units"
      },
      {
        "command": "czaza.analyzeLineRange",
        "title": "CZaza: Analyze Nearby Lines"
      },
      {
        "command": "czaza.copyForAI.copyFile",
        "title": "CZaza: Copy File ❤️",
        "icon": "$(diff)"
      },
      {
        "command": "czaza.copyForAI.copyFileDiff",
        "title": "CZaza: Copy File Diff ❤️",
        "icon": "$(diff)"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "czaza.copyForAI.copyFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@2"
        },
        {
          "command": "czaza.copyForAI.copyFileDiff",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "navigation@3"
        },
        {
          "command": "czaza.showDescription",
          "group": "navigation@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "czaza.copyForAI.copyFile",
          "when": "resourceScheme == file",
          "group": "1_cutcopypaste@200"
        },
        {
          "command": "czaza.copyForAI.copyFileDiff",
          "when": "resourceScheme == file",
          "group": "1_cutcopypaste@201"
        }
      ]
    },
    "configuration": {
      "title": "CZaza",
      "properties": {
        "czaza.descriptionHighlightColor": {
          "type": "string",
          "default": "#22c55e",
          "description": "Highlight color for user-added CZaza descriptions."
        },
        "czaza.deepSeekApiKey": {
          "type": "string",
          "default": "",
          "description": "DeepSeek API key used by CZaza AI analysis in VS Code."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "czaza",
          "title": "CZaza",
          "icon": "media/czaza-icon.svg"
        }
      ]
    },
    "views": {
      "czaza": [
        {
          "type": "webview",
          "id": "czaza.descriptionView",
          "name": "CZaza Description"
        }
      ]
    }
  }
}
